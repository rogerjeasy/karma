# Copy this file to .env.local and fill in the values.
# .env.local is never committed — it overrides .env.production for local dev.

# ── API ────────────────────────────────────────────────────────────────────────
# Local dev  → http://localhost:8001
# Production → https://karma-api-957527396263.us-central1.run.app
NEXT_PUBLIC_API_URL=http://localhost:8001

# ── Firebase (client-side) ─────────────────────────────────────────────────────
# Firebase Console → Project Settings → General → Your apps → Web app → SDK config
NEXT_PUBLIC_FIREBASE_API_KEY=<your-firebase-api-key>
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=gptuesser-firebase.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=gptuesser-firebase
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=gptuesser-firebase.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<your-messaging-sender-id>
NEXT_PUBLIC_FIREBASE_APP_ID=<your-firebase-app-id>
