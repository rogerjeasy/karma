# Karma — root environment file (single source of truth for all services)
# Copy to .env at the repo root — never commit .env
#
# Both api/ and agents/ read this file automatically via file-relative path resolution.
# web/ uses web/.env.local (Next.js convention — see web/.env.local.example).

# ── Google Cloud ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=skillbridge-76a4c
GCP_LOCATION=us-central1
FIRESTORE_DATABASE=(default)

# ── Dynatrace ─────────────────────────────────────────────────────────────────
# DT_ENV is the environment subdomain: https://<DT_ENV>.apps.dynatrace.com
# All Dynatrace URLs are derived from this single value — nothing else needed.
# NOTE: DT_TENANT and DT_TENANT_ID are not recognised — use DT_ENV only.
DT_ENV=<your-environment-name>

# Platform Token — Bearer auth for MCP gateway (see docs/DYNATRACE_SETUP.md §2)
DT_API_TOKEN=<your-platform-token>

# Classic API token — scopes: logs.ingest, openTelemetryTrace.ingest, metrics.ingest
DT_OTEL_TOKEN=<your-otel-api-token>

# MCP server URL — leave blank; derived from DT_ENV automatically.
# Override only for local stdio fallback: DT_MCP_URL=stdio://localhost
# WARNING: pydantic-settings does NOT expand ${VAR} references — set a literal value or leave blank.
DT_MCP_URL=

# ── API gateway ───────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=<generate-a-random-secret>
ALLOWED_ORIGINS=http://localhost:3000,https://<your-production-domain>

# ── Vertex AI / Agent Engine ──────────────────────────────────────────────────
MEMORY_BANK_ID=<memory-bank-resource-id>
AGENT_ENGINE_RESOURCE_NAME=projects/skillbridge-76a4c/locations/us-central1/reasoningEngines/<id>

# ── Watcher ───────────────────────────────────────────────────────────────────
WATCHER_INTERVAL_SECONDS=600

# ── Contract validation ───────────────────────────────────────────────────────
MIN_CONFIDENCE_THRESHOLD=0.75
VALIDATION_HISTORICAL_DAYS=14

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Synthetic environment ─────────────────────────────────────────────────────
# Local dev: redis://localhost:6379 (docker-compose starts Redis on this port)
# Cloud Run: redis://<memorystore-host>:6379 (set via REDIS_URL GitHub variable)
REDIS_URL=redis://localhost:6379

# ── OTel SDK (synthetic-env services only) ───────────────────────────────────
# Consumed by the OpenTelemetry SDK, not by pydantic-settings.
# Derive values from DT_ENV and DT_OTEL_TOKEN above:
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://<DT_ENV>.live.dynatrace.com/api/v2/otlp
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Api-Token <DT_OTEL_TOKEN>
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=






